# Zerly Backend — Environment Variables
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ──────────────────────────────────────────────
# Database (Neon PostgreSQL)
# Get both URLs from the Neon console → Connection Details
# DATABASE_URL  → uses PgBouncer pooled endpoint (for runtime)
# DIRECT_URL    → uses direct (non-pooled) endpoint (for Prisma migrations)


# keep Neon credentials secure: do not expose them to client-side code

DATABASE_URL='postgresql://neondb_owner:npg_SN4q2LCXcpMw@ep-fragrant-lab-a112by9x-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require'
# ──────────────────────────────────────────────
DIRECT_URL="postgresql://neondb_owner:npg_SN4q2LCXcpMw@ep-fragrant-lab-a112by9x-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ──────────────────────────────────────────────
# JWT
# Generate secrets with: node -e "require('crypto').randomBytes(64).toString('hex')|Write-Output"
# ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-access-token-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-different-from-above
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_SECONDS=604800

# ──────────────────────────────────────────────
# GitHub OAuth App
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/auth/github/callback
# ──────────────────────────────────────────────
GITHUB_CLIENT_ID=Ov23li3BxkIQruzWf4Ia
GITHUB_CLIENT_SECRET=66f6dd7399cd8239eabe8a639d2a9a8ce5470410
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback

# ──────────────────────────────────────────────
# Stripe
# Dashboard: https://dashboard.stripe.com/apikeys
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Stripe Price IDs — create these in the Stripe dashboard
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_TEAM_MONTHLY=price_team_monthly_id
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly_id

# ──────────────────────────────────────────────
# Frontend / Extension redirect target
# ──────────────────────────────────────────────
FRONTEND_URL=vscode://zerlyai.zerly
