{
  "name": "zerly-ai",
  "displayName": "Zerly AI",
  "description": "Understand your code. Not just generate it. — Developer intelligence assistant for codebase understanding, architecture visualization, risk detection, and AI code explanation.",
  "version": "0.1.0",
  "publisher": "zerly",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Education",
    "Other"
  ],
  "keywords": [
    "ai",
    "code understanding",
    "architecture",
    "developer tools",
    "code analysis",
    "risk detection"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "assets/zerly-icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "zerly-sidebar",
          "title": "Zerly AI",
          "icon": "assets/zerly-sidebar.svg"
        }
      ]
    },
    "views": {
      "zerly-sidebar": [
        {
          "type": "webview",
          "id": "zerly.mainView",
          "name": "Zerly AI"
        }
      ]
    },
    "commands": [
      {
        "command": "zerly.analyzeProject",
        "title": "Zerly: Analyze Project"
      },
      {
        "command": "zerly.architectureMap",
        "title": "Zerly: Architecture Map"
      },
      {
        "command": "zerly.featureFlow",
        "title": "Zerly: Feature Flow Explorer"
      },
      {
        "command": "zerly.riskScanner",
        "title": "Zerly: Risk Scanner"
      },
      {
        "command": "zerly.explainCode",
        "title": "Zerly: Explain Code"
      },
      {
        "command": "zerly.learningMode",
        "title": "Zerly: Learning Mode"
      },
      {
        "command": "zerly.chat",
        "title": "Zerly: Chat with Zerly"
      },
      {
        "command": "zerly.login",
        "title": "Zerly: Sign in with GitHub"
      },
      {
        "command": "zerly.connectZerly",
        "title": "Zerly: Connect Zerly Account"
      },
      {
        "command": "zerly.logout",
        "title": "Zerly: Sign Out"
      },
      {
        "command": "zerly.upgrade",
        "title": "Zerly: Upgrade Plan"
      },
      {
        "command": "zerly.manageBilling",
        "title": "Zerly: Manage Billing"
      },
      {
        "command": "zerly.architectureHistory",
        "title": "Zerly: Architecture Change History"
      },
      {
        "command": "zerly.teamDashboard",
        "title": "Zerly: Team Dashboard"
      },
      {
        "command": "zerly.refresh",
        "title": "Zerly: Refresh"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "zerly.explainCode",
          "group": "zerly",
          "when": "editorHasSelection"
        }
      ]
    },
    "configuration": {
      "title": "Zerly AI",
      "properties": {
        "zerly.zerlyApiKey": {
          "type": "string",
          "default": "",
          "description": "Your Zerly API key for AI-powered analysis.",
          "markdownDescription": "Your Zerly API key from [zerly.tinobritty.me](https://zerly.tinobritty.me). Required for all AI features."
        },
        "zerly.customModelApiKey": {
          "type": "string",
          "default": "",
          "description": "Optional: API key for a custom model provider. When set, overrides the default Zerly model.",
          "markdownDescription": "Optional: API key for your own model provider. When set, Zerly will use this instead of the default `zerly/zerlino-32b` model."
        },
        "zerly.customModel": {
          "type": "string",
          "default": "",
          "description": "Custom model name to use when a Custom Model API Key is configured."
        },
        "zerly.customApiEndpoint": {
          "type": "string",
          "default": "",
          "description": "Custom API endpoint. Only used when Custom Model API Key is set."
        },
        "zerly.enableRiskScanner": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Risk Scanner to detect fragile and high-complexity modules."
        },
        "zerly.enableArchitectureMap": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Architecture Map to generate visual dependency diagrams."
        }
      }
    },
    "uriHandler": true
  },
  "scripts": {
    "vscode:prepublish": "npm run build:all",
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "build:webview": "node esbuild.webview.config.js",
    "build:all": "node esbuild.config.js && node esbuild.webview.config.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.44",
    "axios": "^1.13.6",
    "mermaid": "^11.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brittytino/zerly"
  }
}
